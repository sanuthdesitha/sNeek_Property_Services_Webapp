// ─────────────────────────────────────────────
// Message Templates + Client Automation Rules
// ─────────────────────────────────────────────

model MessageTemplate {
  id          String   @id @default(cuid())
  name        String
  triggerType String   @default("MANUAL") // "POST_JOB" | "REVIEW_REQUEST" | "DISCOUNT" | "NEXT_CLEAN" | "MANUAL"
  jobType     String?  // null = all job types; specific JobType string for targeted
  channel     String   // "EMAIL" | "SMS" | "BOTH"
  category    MessageCategory @default(CUSTOM)
  subject     String?  // email subject — supports {{variables}}
  body        String   @db.Text // body with {{client_name}}, {{property_address}}, {{cleaner_name}}, {{next_clean_date}}, {{job_type}}, {{feedback_url}}
  variables   Json?    // declared template variables (for autocomplete)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  automationRules ClientAutomationRule[]
  emailCampaigns  EmailCampaign[]        @relation("MessageTemplateCampaigns")

  @@index([category, isActive])
}

enum MessageCategory {
  CHASE
  MARKETING
  OPERATIONAL
  SERVICE_RECOVERY
  FEEDBACK
  COMPLAINT
  ONBOARDING
  CLEANER_FACING
  LAUNDRY_FACING
  INTERNAL
  CUSTOM
}

model ClientAutomationRule {
  id           String   @id @default(cuid())
  clientId     String
  triggerType  String   // "POST_JOB_REVIEW" | "POST_JOB_NEXT_CLEAN" | "POST_JOB_DISCOUNT" | "POST_JOB_CUSTOM"
  jobType      String?  // null = all job types
  templateId   String?
  delayMinutes Int      @default(120)
  isEnabled    Boolean  @default(false) // OFF by default — admin must enable
  channel      String   @default("EMAIL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([clientId, isEnabled])
}

// ─────────────────────────────────────────────
// Job Feedback (post-clean client reviews)
// ─────────────────────────────────────────────

model JobFeedback {
  id             String    @id @default(cuid())
  jobId          String    @unique
  clientId       String
  token          String    @unique @default(cuid()) // public URL token
  rating         Int?      // overall 1–5, null until submitted
  // Client-perspective aspect ratings (1–5) — this is a satisfaction review, NOT
  // a QA inspection score. Kept entirely separate from QAReview.
  cleanlinessRating    Int?
  communicationRating  Int?
  valueRating          Int?
  wouldRecommend       Boolean?
  comment        String?   @db.Text
  submittedAt    DateTime?
  tokenExpiresAt DateTime
  createdAt      DateTime  @default(now())

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
