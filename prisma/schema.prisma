  deliveryStatus String?             // PENDING | DELIVERED | BOUNCED | OPENED
  createdAt      DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id])

  // The notification SSE stream polls by (userId, channel, createdAt) every few
  // seconds per connected user — must be indexed to avoid full table scans.
  @@index([userId, channel, createdAt])
  @@index([createdAt])
}

