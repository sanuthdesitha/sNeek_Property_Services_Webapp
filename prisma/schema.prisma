  invoiceNumber         String              @unique
  status                ClientInvoiceStatus @default(DRAFT)
  periodStart           DateTime?
  periodEnd             DateTime?
  subtotal              Float               @default(0)
  gstAmount             Float               @default(0)
  totalAmount           Float               @default(0)
  gstEnabled            Boolean             @default(true)
  xeroExportedAt        DateTime?
  xeroInvoiceId         String?
  sentAt                DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  metadata              Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lines               ClientInvoiceLine[]
  shoppingSettlements ShoppingSettlement[]
  payments            ClientPayment[]

  @@index([status])
  @@index([clientId, status])
}

// A cleaner's own invoice, snapshotted when they "send" it, so admin can review
// it and push it to Xero as a bill (ACCPAY).
model CleanerInvoiceSubmission {
  id             String    @id @default(cuid())
  cleanerId      String
  periodStart    DateTime
  periodEnd      DateTime
  hours          Float     @default(0)
  totalAmount    Float     @default(0)
  jobCount       Int       @default(0)
  lineData       Json? // snapshot: cleaner contact + line rows for the Xero bill
  status         String    @default("SUBMITTED") // SUBMITTED | XERO_PUSHED
  xeroBillId     String?
  xeroExportedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([cleanerId])
  @@index([status])
}

model ClientInvoiceLine {
  id            String   @id @default(cuid())
  invoiceId     String
  jobId         String?
  shoppingRunId String?
  description   String
  note          String?  @db.Text // per-job note snapshotted from Job.invoiceNote at generation time
  quantity      Float    @default(1)
  unitPrice     Float    @default(0)
  lineTotal     Float    @default(0)
  category      String
  sortOrder     Int      @default(0) // admin-controlled ordering (group by property + drag)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice     ClientInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  job         Job?          @relation(fields: [jobId], references: [id])
  shoppingRun ShoppingRun?  @relation(fields: [shoppingRunId], references: [id])

  // generateClientInvoice scans lines by jobId to skip already-invoiced jobs.
  @@index([jobId])
  @@index([invoiceId])
}

model UserNotificationPreference {
