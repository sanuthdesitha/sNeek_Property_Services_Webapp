// ─────────────────────────────────────────────
// Finance: Payroll, Payments, Xero, Notifications
// ─────────────────────────────────────────────

enum PayrollRunStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  COMPLETED
  FAILED
  VOID
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PayoutMethod {
  STRIPE_CONNECT
  ABA_FILE
  MANUAL_BANK_TRANSFER
  PAYPAL
}

enum GatewayProvider {
  STRIPE
  PAYPAL
  SQUARE
}

enum GatewayStatus {
  ACTIVE
  INACTIVE
  TEST
}

enum NotificationRecipientRole {
  ADMIN
  CLEANER
  CLIENT
}

enum NotificationLogStatus {
  SENT
  FAILED
  SKIPPED
}

enum OnboardingSurveyStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum OnboardingSourceType {
  ADMIN_CREATED
  CLIENT_SUBMITTED
  WEB_FORM
}

model PayrollRun {
  id                        String            @id @default(cuid())
  periodStart               DateTime
  periodEnd                 DateTime
  status                    PayrollRunStatus  @default(DRAFT)
  totalPayable              Float             @default(0)
  totalShoppingReimbursements Float           @default(0)
  totalTransportAllowances  Float             @default(0)
  totalAdjustments          Float             @default(0)
  grandTotal                Float             @default(0)
  cleanerCount              Int               @default(0)
  createdByUserId           String?
  confirmedAt               DateTime?
  completedAt               DateTime?
  // Set when an ABA bank file has been generated for this run. Used to warn on
  // regeneration so the same batch isn't uploaded to the bank twice.
  abaGeneratedAt            DateTime?
  abaGeneratedById          String?
  notes                     String?           @db.Text
  metadata                  Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  createdBy  User?    @relation("PayrollRunCreatedBy", fields: [createdByUserId], references: [id])
  payouts    Payout[]

  @@index([status, createdAt])
  @@index([periodStart, periodEnd])
}

model Payout {
  id                    String        @id @default(cuid())
  payrollRunId          String
  cleanerId             String
  amount                Float
  shoppingReimbursement Float         @default(0)
  transportAllowance    Float         @default(0)
  adjustments           Float         @default(0)
  status                PayoutStatus  @default(PENDING)
  method                PayoutMethod  @default(MANUAL_BANK_TRANSFER)
  stripeAccountId       String?
  stripePayoutId        String?
  bankBsb               String?
  bankAccountNumber     String?
  bankAccountName       String?
  abaReference          String?
  processedAt           DateTime?
  failureReason         String?       @db.Text
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  cleaner    User       @relation("CleanerPayouts", fields: [cleanerId], references: [id])

  @@index([payrollRunId, status])
  @@index([cleanerId, status])
}

model PaymentGateway {
