  surchargeEnabled Boolean         @default(false)
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  payments ClientPayment[]

  @@index([status, priority])
}

model ClientPayment {
  id               String   @id @default(cuid())
  invoiceId        String?
  quoteId          String?
  amount           Float
  currency         String   @default("AUD")
  status           String   @default("PENDING")
  gatewayId        String
  gatewayProvider  GatewayProvider
  gatewayPaymentId String?
  gatewayResponse  Json?
  feeAmount        Float?
  surchargeAmount  Float    @default(0)
  paidAt           DateTime?
  refundedAt       DateTime?
  refundAmount     Float?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invoice ClientInvoice? @relation(fields: [invoiceId], references: [id])
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])

  @@index([invoiceId, status])
  @@index([gatewayId, status])
}

model XeroConnection {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  tenantName    String
  accessToken   String    @db.Text
  refreshToken  String    @db.Text
  expiresAt     DateTime
  scopes        String[]
  isActive      Boolean   @default(true)
  lastSyncAt    DateTime?
  lastSyncError String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model NotificationTemplate {
  id            String   @id @default(cuid())
  eventKey      String   @unique
  label         String
  category      String
  description   String?  @db.Text
  emailSubject  String?
  emailBodyHtml String?  @db.Text
  emailBodyText String?  @db.Text
  smsBody       String?  @db.Text
  pushTitle     String?
  pushBody      String?
  availableVars Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NotificationPreference {
  id            String                  @id @default(cuid())
  eventKey      String
  recipientRole NotificationRecipientRole
  channel       NotificationChannel
  enabled       Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([eventKey, recipientRole, channel])
  @@index([eventKey])
}

model NotificationLog {
  id             String   @id @default(cuid())
  eventKey       String
  recipientEmail String?
  recipientRole  String
  channel        NotificationChannel
  status         NotificationLogStatus
  subject        String?
  error          String?  @db.Text
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([eventKey, createdAt])
  @@index([recipientEmail, createdAt])
}

// ─────────────────────────────────────────────
// Property Onboarding
// ─────────────────────────────────────────────

model PropertyOnboardingSurvey {
  id                    String                  @id @default(cuid())
  surveyNumber          String                  @unique
  sourceType            OnboardingSourceType    @default(ADMIN_CREATED)
  status                OnboardingSurveyStatus  @default(DRAFT)
  submittedById         String?
  adminReviewerId       String?
  reviewedAt            DateTime?
  rejectionReason       String?                 @db.Text

  // Client linkage
  isNewClient           Boolean                 @default(false)
  clientData            Json?                   // { name, email, phone, address, notes }
  existingClientId      String?

  // Property basics
  propertyAddress       String?
  propertySuburb        String?
  propertyState         String                  @default("NSW")
  propertyPostcode      String?
  propertyName          String?
  propertyNotes         String?                 @db.Text

  bedrooms              Int                     @default(1)
  bathrooms             Int                     @default(1)
  hasBalcony            Boolean                 @default(false)
  floorCount            Int                     @default(1)
  propertyType          String?                 // HOUSE, APARTMENT, TOWNHOUSE, UNIT, DUPLEX
  sizeSqm               Float?

  // Staffing & estimation
  requestedCleanerCount Int                     @default(1)
  estimatedCleanerCount Int?
  estimatedHours        Float?
  estimatedPrice        Float?

  // iCal (optional)
  icalUrl               String?                 @db.Text
  icalProvider          IntegrationProvider?    @default(ICAL_OTHER)

  // Laundry supplier assignment
  laundrySupplierId     String?
  laundrySupplier       LaundrySupplier?        @relation(fields: [laundrySupplierId], references: [id])

  // Approval/edit
  adminNotes            String?                 @db.Text
  adminOverrides        Json?                   // { cleanerCount, hours, price, ... }

  // Created entities on approval
  createdClientId       String?
  createdPropertyId     String?
  createdIntegrationId  String?
  createdLaundryTaskId  String?
  createdJobIds         String[]                @default([])

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  submittedAt           DateTime?

  submittedBy           User?                   @relation("OnboardingSubmittedBy", fields: [submittedById], references: [id])
  adminReviewer         User?                   @relation("OnboardingReviewedBy", fields: [adminReviewerId], references: [id])
  existingClient        Client?                 @relation("OnboardingExistingClient", fields: [existingClientId], references: [id])
  createdClient         Client?                 @relation("OnboardingCreatedClient", fields: [createdClientId], references: [id])

  appliances            OnboardingAppliance[]
  specialRequests       OnboardingSpecialRequest[]
  laundryDetail         OnboardingLaundryDetail?
  accessDetails         OnboardingAccessDetail[]
  jobTypeAnswers        OnboardingJobTypeAnswer[]

  @@index([status, createdAt])
  @@index([sourceType, status])
  @@index([existingClientId])
  @@index([createdPropertyId])
}

model OnboardingAppliance {
  id            String                    @id @default(cuid())
  surveyId      String
  applianceType String                    // OVEN, FRIDGE, DISHWASHER, WASHER, DRYER, RANGEHOOD, MICROWAVE
  conditionNote String?                   @db.Text
  requiresClean Boolean                   @default(true)

  survey        PropertyOnboardingSurvey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model OnboardingSpecialRequest {
  id            String                    @id @default(cuid())
  surveyId      String
  description   String                    @db.Text
  priority      String                    @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  area          String?                   // KITCHEN, BATHROOM, BEDROOM, LIVING, OUTDOOR, GARAGE

  survey        PropertyOnboardingSurvey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model OnboardingLaundryDetail {
  id              String                    @id @default(cuid())
  surveyId        String                    @unique
  hasLaundry      Boolean                   @default(false)
  washerType      String?                   // FRONT_LOAD, TOP_LOAD, COMBO
  dryerType       String?                   // DRYER, COMBO, NONE
  laundryLocation String?                   // INSIDE_UNIT, SEPARATE_ROOM, GARAGE, OUTDOOR
  suppliesProvided Boolean                  @default(false)
  detergentType   String?                   // STANDARD, HYPOALLERGENIC, ECO, CLIENT_PROVIDED
  notes           String?                   @db.Text

  survey          PropertyOnboardingSurvey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model OnboardingAccessDetail {
  id            String                    @id @default(cuid())
  surveyId      String
  detailType    String                    // LOCKBOX, KEY_LOCATION, PARKING, ENTRY_PHOTO, BUILDING_ACCESS
  value         String?                   @db.Text
  photoUrl      String?                   @db.Text
  photoKey      String?
  annotations   Json?                     // [{ x, y, text }]
  sortOrder     Int                       @default(0)

  survey        PropertyOnboardingSurvey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model OnboardingJobTypeAnswer {
  id            String                    @id @default(cuid())
  surveyId      String
  jobType       JobType
  answers       Json                      // { questionId: answer }
  isComplete    Boolean                   @default(false)

  survey        PropertyOnboardingSurvey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, jobType])
  @@index([surveyId])
}

model UploadFailure {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  filename    String
  size        Int
  mime        String
  reason      String    // canonical short code, e.g. "S3_TIMEOUT", "PRESIGN_REJECTED", "CLIENT_ABORT"
  message     String?
  stack       String?   @db.Text
  context     Json?     // optional payload (file slice index, retry count, etc.)
  occurredAt  DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([jobId])
  @@index([resolvedAt])
}

// Geocode failures (Plan D backfill)
model GeocodeFailure {
  id          String   @id @default(cuid())
  modelType   String   // "Property" | "User" | "Client"
  modelId     String
  query       String
  reason      String
  occurredAt  DateTime @default(now())
  resolvedAt  DateTime?
  @@index([modelType, modelId])
  @@index([resolvedAt])
}
