  invoiceDayOfWeek       Int?
  invoiceDayOfMonth      Int?
  preferredPayoutMethod  PayoutMethod     @default(MANUAL_BANK_TRANSFER)
  lastInvoiceGeneratedAt DateTime?

  // V9 cleaner onboarding fields
  address                  String?
  dateOfBirth              DateTime?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Identity (cleaner-specific)
  visaStatus               VisaStatus?
  // TODO: encrypt at rest if we ever store the actual TFN
  taxFileNumberOnFile      Boolean    @default(false)

  // Employment
  employmentType           EmploymentType?
  abn                      String?
  hireDate                 DateTime?

  // Skills
