model QuizTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  schema      Json     // { title, intro, passThreshold, questions: AssessmentQuestion[] }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments QuizAssignment[]
}

enum QuizAssignmentStatus {
  PENDING
  COMPLETED
  EXPIRED
}

/// A specific quiz assigned to a candidate, completed via an emailed link.
model QuizAssignment {
  id             String               @id @default(cuid())
  applicationId  String
  quizTemplateId String
  token          String               @unique
  status         QuizAssignmentStatus @default(PENDING)
  score          Float?
  result         Json?
  answers        Json?
  // When several quizzes are sent COMBINED, the merged AssessmentSchema is
  // snapshotted here (and a display title in `title`). When null, the linked
  // quizTemplate's schema is used. quizTemplateId still points at the first part.
  schema         Json?
  title          String?
  sentAt         DateTime?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())

  application  HiringApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  quizTemplate QuizTemplate      @relation(fields: [quizTemplateId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([token])
}

