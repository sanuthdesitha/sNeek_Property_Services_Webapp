// ─────────────────────────────────────────────
// Clients + Properties
// ─────────────────────────────────────────────

model Client {
  id                        String   @id @default(cuid())
  name                      String
  email                     String?
  phone                     String?
  address                   String?
  notes                     String?  @db.Text
  portalVisibilityOverrides Json?
  isActive                  Boolean  @default(true)
  xeroContactId             String?
  xeroSyncedAt              DateTime?
  latitude                  Float?
  longitude                 Float?
  placeId                   String?
  suburb                    String?
  state                     String?
  postcode                  String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  properties           Property[]
  users                User[]
  quotes               Quote[]
  jobTasks             JobTask[]
  leads                QuoteLead[]
  cases                IssueTicket[]
  shoppingRuns         ShoppingRun[]
  invoices             ClientInvoice[]
  loyaltyAccount       LoyaltyAccount?
  referralsMade        Referral[]                 @relation("ReferralReferrer")
  referralsConverted   Referral[]                 @relation("ReferralReferee")
  satisfactionRatings  ClientSatisfactionRating[]
  messages             ClientMessage[]
  notificationPref     ClientNotificationPreference?
  automationRules      ClientAutomationRule[]
  jobFeedback          JobFeedback[]
  lastReviewRequestSentAt DateTime?
  onboardingSurveys    PropertyOnboardingSurvey[]  @relation("OnboardingExistingClient")
  createdOnboardingSurveys PropertyOnboardingSurvey[] @relation("OnboardingCreatedClient")
}

model Property {
  id                     String   @id @default(cuid())
  clientId               String
  name                   String
  address                String
  suburb                 String
  state                  String   @default("NSW")
  postcode               String?
  imageUrl               String?  // optional cover photo shown on the properties grid
  notes                  String?  @db.Text
  accessInfo             Json? // { lockbox, codes, parking, other }
  linenBufferSets        Int      @default(0)
  inventoryEnabled       Boolean  @default(false)
  defaultCheckinTime     String   @default("14:00") // HH:mm
  defaultCheckoutTime    String   @default("10:00") // HH:mm
  // Where job start/due times come from: the property's configured default
  // times ("PROPERTY") or the imported iCal/reservation event times ("ICAL").
  jobTimeSource          String   @default("PROPERTY")
  hasBalcony             Boolean  @default(false)
  bedrooms               Int      @default(1)
  bathrooms              Int      @default(1)
  latitude               Float?
  longitude              Float?
  accessCode             String?  @db.Text
  alarmCode              String?  @db.Text
  keyLocation            String?
  accessNotes            String?  @db.Text
  preferredCleanerUserId     String?
  showCleanerContactToClient Boolean  @default(false)
  laundryEnabled             Boolean  @default(true) // false = no laundry service for this property
  isActive                   Boolean  @default(true)
  /// Amenity/feature flags driving the per-property checklist composition —
  /// { dishwasher, oven, microwave, fridge, washer, dryer, rangehood, bbq,
  ///   pool, spa, garage, garden, petFriendly, fireplace, ... }: boolean.
  /// Copied from the onboarding survey on approval; editable on the property.
  features                   Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  placeId          String?

  client           Client                 @relation(fields: [clientId], references: [id])
  preferredCleaner User?                  @relation("PropertyPreferredCleaner", fields: [preferredCleanerUserId], references: [id])
  integration      Integration?
  reservations     Reservation[]
  jobs             Job[]
  propertyStock    PropertyStock[]
  laundryTasks     LaundryTask[]
  icalSyncRuns     IcalSyncRun[]
  cases            IssueTicket[]
  stockRuns        StockRun[]
  shoppingRunLines ShoppingRunLine[]
  clientRates      PropertyClientRate[]
  payAdjustments   CleanerPayAdjustment[]
  jobTasks         JobTask[]
  qaFormTemplates  QaFormTemplate[]
  maintenanceItems PropertyMaintenanceItem[]
  heldStockDeliveries HeldStockDelivery[]
  checklistProfile PropertyChecklistProfile?

  @@index([placeId])
  @@index([suburb])
}

// ─────────────────────────────────────────────
// Checklist library — the database of checklist content, organised into
// modules (rooms / appliances / outdoor areas / extras) that compose into a
// per-property cleaner form. Modules auto-apply via `appliesWhen` rules
// against the property's attributes/features and can be toggled per property.
// ─────────────────────────────────────────────

model ChecklistModule {
  id          String  @id @default(cuid())
  /// Stable key, e.g. "kitchen", "balcony", "dishwasher".
  key         String  @unique
  title       String
  /// ROOM | APPLIANCE | OUTDOOR | SAFETY | EXTRA
  category    String  @default("ROOM")
  description String? @db.Text
  /// Auto-apply rule evaluated against the property:
  ///   { feature: "dishwasher" }                     → features.dishwasher === true
  ///   { propertyField: "hasBalcony", equals: true } → property column match
  ///   null                                          → always applies
  appliesWhen Json?
  /// Repeat this module's section per counted attribute: "bedrooms" | "bathrooms".
  repeatBy    String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  items ChecklistModuleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model ChecklistModuleItem {
  id           String  @id @default(cuid())
  moduleId     String
  /// Stable key doubling as the generated form-field id, e.g. "kitchen.benchtops".
  key          String
  label        String
  instructions String? @db.Text
  imageUrl     String? @db.Text
  videoUrl     String? @db.Text
  /// checkbox (default) | yesno | photo | video — maps to the form field type.
  fieldType    String  @default("checkbox")
  required     Boolean @default(false)
  minPhotos    Int?
  /// Evidence stamp tag for photo/video items: before | after | damage.
  stampTag     String?
  /// Ticked by default when the module applies (admin can still turn off).
  defaultOn    Boolean @default(true)
  /// Which job types include this item (empty = all job types).
  jobTypes     JobType[]
  /// Optional per-item auto-apply rule (same shape as the module rule) for
  /// items inside a broader module, e.g. the dishwasher line in "Kitchen".
  appliesWhen  Json?
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)

  module ChecklistModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, key])
  @@index([moduleId, sortOrder])
}

/// One checklist profile per property: which modules/items are on or off (with
/// per-job-type item flags), custom items, and the approval + generated
/// FormTemplate linkage. Approving materialises FormTemplate(s) and registers
/// them in AppSettings.propertyFormTemplateOverrides for this property only.
model PropertyChecklistProfile {
  id         String @id @default(cuid())
  propertyId String @unique
  /// {
  ///   modules: { [moduleKey]: { enabled: bool, items: { [itemKey]: { enabled: bool, jobTypes?: JobType[] } } } },
  ///   customItems: [{ id, moduleKey?, label, instructions?, fieldType?, jobTypes?: JobType[] }]
  /// }
  selections Json
  /// DRAFT | APPROVED | STALE (STALE = features/library changed since approval).
  status     String @default("DRAFT")
  approvedById String?
  approvedAt   DateTime?
  /// { [jobType]: generatedFormTemplateId } — the materialised per-property forms.
  generatedTemplateIds Json?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("ChecklistProfileApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id               String              @id @default(cuid())
  propertyId       String              @unique
  provider         IntegrationProvider @default(ICAL_HOSPITABLE)
  icalUrl          String?             @db.Text
  isEnabled        Boolean             @default(false)
  lastSyncAt       DateTime?
  lastSyncEtag     String?
  lastSyncModified String?
  syncStatus       SyncStatus          @default(IDLE)
  syncError        String?             @db.Text
  notes            String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  property Property      @relation(fields: [propertyId], references: [id])
  syncRuns IcalSyncRun[]
}

model IcalSyncRun {
  id            String    @id @default(cuid())
  integrationId String
  propertyId    String
  triggeredById String?
  revertedById  String?
  mode          String    @default("MANUAL")
  status        String    @default("RUNNING")
  summary       Json?
  snapshot      Json?
  error         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  revertedAt    DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation("IcalSyncTriggeredBy", fields: [triggeredById], references: [id])
  revertedBy  User?       @relation("IcalSyncRevertedBy", fields: [revertedById], references: [id])

  @@index([integrationId, createdAt])
  @@index([propertyId, createdAt])
}

model Reservation {
  id              String    @id @default(cuid())
  propertyId      String
  uid             String // iCal UID
  startDate       DateTime // check-in (UTC)
  endDate         DateTime // check-out (UTC)
  summary         String?
  guestName       String?
  reservationCode String?
  guestPhone      String?
  guestEmail      String?
  guestProfileUrl String?   @db.Text
  adults          Int?
  children        Int?
  infants         Int?
  locationText    String?   @db.Text
  geoLat          Float?
  geoLng          Float?
  checkinAtLocal  DateTime?
  checkoutAtLocal DateTime?
  source          String?   @default("ical")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  job      Job?

  @@unique([propertyId, uid])
}

// ─────────────────────────────────────────────
// Jobs
// ─────────────────────────────────────────────

model Job {
  id                    String    @id @default(cuid())
  jobNumber             String    @unique
  propertyId            String
  reservationId         String?   @unique
  jobType               JobType
  status                JobStatus @default(UNASSIGNED)
  scheduledDate         DateTime // date of cleaning (UTC start of day)
  startTime             String? // HH:mm (property local)
  endTime               String? // HH:mm (property local)
  dueTime               String? // latest completion HH:mm
  estimatedHours        Float?
  actualHours           Float?
  notes                 String?   @db.Text
  internalNotes         String?   @db.Text
  // Agreed/negotiated fixed client price for this job. When set, it overrides
  // the property/job-type PropertyClientRate on the client invoice and lets the
  // job be invoiced even if no standard rate exists. null = use the rate table.
  fixedPrice            Float?
  // Note printed on the client invoice line (and shown in the admin invoicing UI).
  invoiceNote           String?   @db.Text
  // Actual completion date/time. Drives which payroll + client-invoice period the
  // job falls into (falls back to scheduledDate when null). Stamped on QA pass and
  // editable by admins for next-day / custom completion dates.
  completedAt           DateTime?
  // Set when this job's cleaner pay has been included in a payroll run. Prevents
  // the same job being paid again in a later/overlapping run (payroll idempotency).
  payrollRunId          String?
  // ── Rework / reclean ──────────────────────────────────────────────────────
  // A rework job is a distinct Job created when QA fails a clean. It carries the
  // QA-flagged areas (+ the photos QA captured) so the cleaner sees exactly what
  // to fix and uploads "after" photos per area. Rework jobs never create laundry
  // pickups. Pay rule: when the SAME cleaner redoes it → no pay (reworkPayAmount
  // null/0); when a DIFFERENT cleaner redoes it → that cleaner is paid
  // reworkPayAmount and the same amount is deducted from the original cleaner.
  isRework                  Boolean   @default(false)
  reworkOfJobId             String?
  reworkReason              String?   @db.Text
  reworkAreas               Json? // [{ id, label, note, photoKeys: string[] }]
  reworkPayAmount           Float? // amount paid to the rework cleaner (and deducted from the original)
  reworkPayeeCleanerId      String? // cleaner who will be paid for the rework
  reworkDeductFromCleanerId String? // original cleaner the amount is deducted from (null = same cleaner)
  reworkDeductionApplied    Boolean   @default(false)
  reworkSourceReviewId      String? // the failing QAReview that triggered this rework
  // Allowed cleaners can clock out before completing the form. The clock stops
  // and the job is parked as "form pending" — it is NOT considered completed
  // until the form is submitted (which then flows through SUBMITTED → QA).
  formPendingAfterClockOut  Boolean   @default(false)
  clockedOutEarlyAt         DateTime?
  priorityBucket        Int       @default(4)
  priorityReason        String?
  sameDayCheckin        Boolean   @default(false)
  sameDayCheckinTime    String?
  // reminder overrides (null = use system defaults)
  reminder24hSent       Boolean   @default(false)
  reminder2hSent        Boolean   @default(false)
  gpsCheckInLat         Float?
  gpsCheckInLng         Float?
  gpsCheckInAt          DateTime?
  gpsCheckOutLat        Float?
  gpsCheckOutLng        Float?
  gpsCheckOutAt         DateTime?
  gpsDistanceMeters      Int?
  gpsCheckInAccuracyM    Float?
  gpsCheckInConfirmed    Boolean   @default(false)
  gpsCheckInAdjusted     Boolean   @default(false)
  gpsCheckInNote         String?   @db.Text
  requiresSafetyCheckin  Boolean   @default(false)
  safetyCheckinAt        DateTime?
  // Skip / don't-clean: a client can request the clean be skipped, or an admin
  // can set it directly. NONE | REQUESTED | SKIPPED | DECLINED.
  cleanSkipStatus        String    @default("NONE")
  cleanSkipReason        String?   @db.Text
  cleanSkipRequestedById String?
  cleanSkipDecidedById   String?
  cleanSkipAt            DateTime?
  manuallyRescheduledAt   DateTime?
  rescheduledBy           String?
  enRouteStartedAt        DateTime?
  enRouteEtaMinutes       Int?
  enRouteEtaUpdatedAt     DateTime?
  drivingPausedAt         DateTime?
  drivingPauseReason      String?
  drivingDelayedAt        DateTime?
  drivingDelayedReason    String?
  arrivedAt               DateTime?
  lastEtaNotificationAt   DateTime?
  lastEtaNotifiedMinutes  Int?
  lastDelayedNotificationAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  property               Property                   @relation(fields: [propertyId], references: [id])
  reservation            Reservation?               @relation(fields: [reservationId], references: [id])
  reworkOfJob            Job?                       @relation("JobRework", fields: [reworkOfJobId], references: [id], onDelete: SetNull)
  reworkChildren         Job[]                      @relation("JobRework")
  assignments            JobAssignment[]
  timeLogs               TimeLog[]
  formSubmissions        FormSubmission[]
  qaReviews              QAReview[]
  qaAssignments           QaAssignment[]
  qaFormSubmissions       QaFormSubmission[]
  qaReworkTransfers       QaReworkTransfer[]
  mediaOverrideRequests   MediaOverrideRequest[]
  maintenanceItems        PropertyMaintenanceItem[]
  laundryTask            LaundryTask?
  report                 Report?
  issueTickets           IssueTicket[]
  payAdjustments         CleanerPayAdjustment[]
  timeAdjustmentRequests TimeLogAdjustmentRequest[]
  auditLogs              AuditLog[]                 @relation("AuditJob")
  invoiceLines           ClientInvoiceLine[]
  jobTasks               JobTask[]
  satisfactionRating     ClientSatisfactionRating?
  cleanerLocationPings   CleanerLocationPing[]
  feedback               JobFeedback?
  uploadFailures         UploadFailure[]

  // Hot-path indexes: job lists, payroll, invoicing, and dashboards filter/sort
  // on status + scheduledDate/completedAt + propertyId.
  @@index([scheduledDate])
  @@index([status, scheduledDate])
  @@index([propertyId, scheduledDate])
  @@index([completedAt])
  @@index([status, completedAt])
  @@index([payrollRunId])
  @@index([isRework, status])
  @@index([reworkOfJobId])
}

model CleanerPayAdjustment {
  id              String              @id @default(cuid())
  jobId           String?
  propertyId      String?
  cleanerId       String
  scope           PayAdjustmentScope  @default(JOB)
  title           String?
  type            PayAdjustmentType
  requestedHours  Float?
  requestedRate   Float?
  requestedAmount Float
  approvedAmount  Float?
  status          PayAdjustmentStatus @default(PENDING)
  cleanerNote     String?             @db.Text
  attachmentKeys  Json?
  adminNote       String?             @db.Text
  requestedAt     DateTime            @default(now())
  reviewedById    String?
  reviewedAt      DateTime?
  // Stamped with the payroll run that paid this approved adjustment so it can
  // never be included in a second run (idempotency — mirrors Job.payrollRunId
  // and ShoppingSettlement.includedInPayrollRunId).
  includedInPayrollRunId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  job        Job?      @relation(fields: [jobId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
  cleaner    User      @relation("CleanerAdjustmentRequests", fields: [cleanerId], references: [id])
  reviewedBy User?     @relation("CleanerAdjustmentReviews", fields: [reviewedById], references: [id])

  @@index([cleanerId, status])
  @@index([jobId, status])
  @@index([propertyId, status])
  @@index([includedInPayrollRunId])
}

model JobAssignment {
  id                       String                      @id @default(cuid())
  jobId                    String
  userId                   String
  isPrimary                Boolean                     @default(false)
  payRate                  Float? // hourly rate at time of assignment
  assignedAt               DateTime                    @default(now())
  offeredAt                DateTime                    @default(now())
  removedAt                DateTime?
  responseStatus           JobAssignmentResponseStatus @default(PENDING)
  respondedAt              DateTime?
  responseNote             String?                     @db.Text
  assignedById             String?
  transferredFromUserId    String?

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

model TimeLog {
  id        String    @id @default(cuid())
  jobId     String
  userId    String
  startedAt DateTime
  stoppedAt DateTime?
  durationM Int? // minutes (computed on stop)
  notes     String?

  job                Job                        @relation(fields: [jobId], references: [id])
  user               User                       @relation(fields: [userId], references: [id])
  adjustmentRequests TimeLogAdjustmentRequest[]

  // NOTE: a PARTIAL unique index enforces at most one OPEN log per (jobId,
  // userId): `CREATE UNIQUE INDEX "TimeLog_job_user_open_unique" ON "TimeLog"
  // ("jobId","userId") WHERE "stoppedAt" IS NULL;` — see migration
  // 20260703120000_timelog_open_unique. Prisma can't express a partial unique
  // index here, so it lives in raw SQL only. Do NOT add an @@unique for these
  // columns (it would be a FULL unique index and break re-clock-in after stop).
}

model TimeLogAdjustmentRequest {
  id                 String               @id @default(cuid())
  timeLogId          String
  jobId              String
  cleanerId          String
  requestedDurationM Int
  requestedStoppedAt DateTime?
  originalDurationM  Int
  originalStoppedAt  DateTime?
  reason             String?              @db.Text
  status             TimeAdjustmentStatus @default(PENDING)
  reviewedById       String?
  reviewedAt         DateTime?
  adminNote          String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  timeLog    TimeLog @relation(fields: [timeLogId], references: [id], onDelete: Cascade)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cleaner    User    @relation("TimeAdjustmentRequestedBy", fields: [cleanerId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("TimeAdjustmentReviewedBy", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([jobId, status])
  @@index([cleanerId, status])
}

// ─────────────────────────────────────────────
// Forms Engine
// ─────────────────────────────────────────────

model FormTemplate {
  id               String    @id @default(cuid())
  name             String
  serviceType      JobType
  kind             FormKind  @default(CUSTOM)
  version          Int       @default(1)
  isActive         Boolean   @default(true)
  schema           Json // full template JSON (sections → fields → logic)
  parentTemplateId String?
  parentTemplate   FormTemplate?  @relation("FormTemplateLineage", fields: [parentTemplateId], references: [id], onDelete: SetNull)
  children         FormTemplate[] @relation("FormTemplateLineage")
  publishedAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  submissions FormSubmission[]

  @@index([kind, isActive])
}

model FormSubmission {
  id                       String          @id @default(cuid())
  jobId                    String
  templateId               String
  submittedById            String
  data                     Json // cleaner's answers keyed by field id
  laundryReady             Boolean?
  laundryOutcome           LaundryOutcome?
  laundrySkipReasonCode    String?
  laundrySkipReasonNote    String?         @db.Text
  laundryAdminOverrideNote String?         @db.Text
  laundryAdminOverrideById String?
  laundryAdminOverrideAt   DateTime?
  bagLocation              String?
  autoQaScore              Float? // computed on submission
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  job         Job               @relation(fields: [jobId], references: [id])
  template    FormTemplate      @relation(fields: [templateId], references: [id])
  submittedBy User              @relation(fields: [submittedById], references: [id])
  media       SubmissionMedia[]
  stockTxs    StockTx[]
  mediaOverrideRequests MediaOverrideRequest[]
}

model SubmissionMedia {
  id           String    @id @default(cuid())
  submissionId String
  fieldId      String
  mediaType    MediaType
  url          String    @db.Text
  s3Key        String
  originalUrl   String?   @db.Text
  originalS3Key String?
  annotatedUrl  String?   @db.Text
  annotatedS3Key String?
  annotationData Json?
  sizeBytes    Int?
  mimeType     String?
  label        String?
  createdAt    DateTime  @default(now())

  submission FormSubmission @relation(fields: [submissionId], references: [id])
}

model QAReview {
  id           String   @id @default(cuid())
  jobId        String
  reviewedById String? // null if auto-generated
  score        Float
  passed       Boolean
  notes        String?  @db.Text
  flags        Json? // array of field ids that failed
  // Authority of this review. "QA" = a real on-site QA inspection (highest
  // authority — overrides any earlier admin/auto score for the job). "ADMIN" =
  // an admin/ops quick score. "AUTO" = system-generated. The authoritative
  // outcome for a job is the latest QA review if one exists, else the latest of
  // any kind (see lib/qa/authority.ts).
  kind         String   @default("QA") // QA | ADMIN | AUTO
  editedById   String? // admin who last edited this score
  editedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  job        Job   @relation(fields: [jobId], references: [id])
  reviewedBy User? @relation("QAReviewReviewedBy", fields: [reviewedById], references: [id])
  qaFormSubmissions QaFormSubmission[]

  @@index([jobId])
  @@index([jobId, kind, createdAt])
  @@index([createdAt])
}

model QaFormTemplate {
  id          String   @id @default(cuid())
  name        String
  serviceType JobType
  propertyId  String?
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  schema      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property? @relation(fields: [propertyId], references: [id])
  submissions QaFormSubmission[]

  @@index([serviceType, isActive, version])
  @@index([propertyId, serviceType, isActive])
}

model QaAssignment {
  id           String             @id @default(cuid())
  jobId        String
  assignedToId String?
  createdById  String?
  pickedUpById String?
  status       QaAssignmentStatus @default(OPEN)
  dueAt        DateTime?
  pickedUpAt   DateTime?
  completedAt  DateTime?
  onSiteStartedAt DateTime?
  onSiteEndedAt   DateTime?
  onSiteMinutes   Int?
  notes        String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  job          Job   @relation(fields: [jobId], references: [id])
  assignedTo   User? @relation("QaAssignmentAssignedTo", fields: [assignedToId], references: [id])
  createdBy    User? @relation("QaAssignmentCreatedBy", fields: [createdById], references: [id])
  pickedUpBy   User? @relation("QaAssignmentPickedUpBy", fields: [pickedUpById], references: [id])
  submissions  QaFormSubmission[]
  reworkTransfers QaReworkTransfer[]

  @@index([status, dueAt])
  @@index([assignedToId, status])
  @@index([jobId, status])
}

/// A QA-initiated correction record: the inspector flags work the cleaner
/// missed and (optionally) had to redo. With admin approval, billable minutes
/// and/or pay can be moved from the cleaner to the QA inspector, and the
/// cleaner's quality stats reflect the miss. Mirrors the existing pay/time
/// adjustment + approval-gate patterns.
model QaReworkTransfer {
  id              String                 @id @default(cuid())
  jobId           String
  assignmentId    String?
  qaUserId        String
  cleanerUserId   String
  severity        QaReworkSeverity       @default(MINOR)
  reason          String                 @db.Text
  areas           Json?                  // list of areas/items redone
  minutesFromCleaner Int                 @default(0)
  amountFromCleaner  Float               @default(0)
  affectsCleanerStats Boolean            @default(true)
  status          QaReworkTransferStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  adminNote       String?                @db.Text
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  job         Job           @relation(fields: [jobId], references: [id])
  assignment  QaAssignment? @relation(fields: [assignmentId], references: [id])
  qaUser      User          @relation("QaReworkQa", fields: [qaUserId], references: [id])
  cleaner     User          @relation("QaReworkCleaner", fields: [cleanerUserId], references: [id])
  reviewedBy  User?         @relation("QaReworkReviewedBy", fields: [reviewedById], references: [id])

  @@index([jobId, status])
  @@index([cleanerUserId, status])
  @@index([qaUserId, status])
}

enum QaReworkSeverity {
  MINOR
  MODERATE
  MAJOR
}

enum QaReworkTransferStatus {
  PENDING
  APPROVED
  REJECTED
}

model QaFormSubmission {
  id             String   @id @default(cuid())
  jobId          String
  templateId     String
  assignmentId   String?
  qaReviewId     String?
  submittedById  String
  data           Json
  categoryScores Json?
  media          Json?
  score          Float
  passed         Boolean
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job          Job            @relation(fields: [jobId], references: [id])
  template     QaFormTemplate @relation(fields: [templateId], references: [id])
  assignment   QaAssignment?  @relation(fields: [assignmentId], references: [id])
  qaReview     QAReview?      @relation(fields: [qaReviewId], references: [id])
  submittedBy  User           @relation("QaFormSubmissionSubmittedBy", fields: [submittedById], references: [id])

  @@index([jobId, createdAt])
  @@index([submittedById, createdAt])
}

model MediaOverrideRequest {
  id                String              @id @default(cuid())
  jobId             String
  submissionId      String?
  requestedById     String
  decidedById       String?
  fieldId           String
  fieldLabel        String?
  reason            String?             @db.Text
  status            MediaOverrideStatus @default(PENDING)
  decisionNote      String?             @db.Text
  decidedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  job          Job             @relation(fields: [jobId], references: [id])
  submission   FormSubmission? @relation(fields: [submissionId], references: [id])
  requestedBy  User            @relation("MediaOverrideRequestedBy", fields: [requestedById], references: [id])
  decidedBy    User?           @relation("MediaOverrideDecidedBy", fields: [decidedById], references: [id])

  @@index([jobId, status])
  @@index([requestedById, status])
  @@unique([jobId, requestedById, fieldId, status])
}

model IssueTicket {
  id               String   @id @default(cuid())
  jobId            String?
  clientId         String?
  propertyId       String?
  reportId         String?
  title            String
  description      String?  @db.Text
  caseType         String   @default("OPS")
  source           String?
  severity         String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status           String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED (legacy, kept for backward compat)
  state            CaseState @default(OPEN)
  slaBreachAt      DateTime?
  assignedToUserId String?
  clientVisible    Boolean  @default(false)
  clientCanReply   Boolean  @default(true)
  resolutionNote   String?  @db.Text
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job         Job?             @relation(fields: [jobId], references: [id])
  client      Client?          @relation(fields: [clientId], references: [id])
  property    Property?        @relation(fields: [propertyId], references: [id])
  report      Report?          @relation(fields: [reportId], references: [id])
  assignedTo  User?            @relation("IssueTicketAssignedTo", fields: [assignedToUserId], references: [id])
  comments    CaseComment[]
  attachments CaseAttachment[]
  transitions CaseTransition[]
}

model CaseTransition {
  id         String      @id @default(cuid())
  caseId     String
  case       IssueTicket @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromState  CaseState?
  toState    CaseState
  actorId    String?
  actor      User?       @relation("CaseTransitionActor", fields: [actorId], references: [id], onDelete: SetNull)
  reason     String?     @db.Text
  occurredAt DateTime    @default(now())

  @@index([caseId, occurredAt])
  @@index([toState])
}

model JobTask {
  id                String                 @id @default(cuid())
  jobId             String?
  propertyId        String
  clientId          String?
  source            JobTaskSource
  approvalStatus    JobTaskApprovalStatus  @default(APPROVED)
  executionStatus   JobTaskExecutionStatus @default(OPEN)
  title             String
  description       String?                @db.Text
  requiresPhoto     Boolean                @default(false)
  requiresNote      Boolean                @default(false)
  visibleToCleaner  Boolean                @default(false)
  requestedByUserId String?
  approvedByUserId  String?
  parentTaskId      String?
  autoApproveAt     DateTime?
  approvedAt        DateTime?
  completedAt       DateTime?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  job         Job?                @relation(fields: [jobId], references: [id])
  property    Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client      Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  requestedBy User?               @relation("JobTaskRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedBy  User?               @relation("JobTaskApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  parentTask  JobTask?            @relation("JobTaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks  JobTask[]           @relation("JobTaskParent")
  attachments JobTaskAttachment[]
  events      JobTaskEvent[]

  @@index([jobId, approvalStatus, executionStatus])
  @@index([propertyId, approvalStatus, executionStatus])
  @@index([clientId, approvalStatus, executionStatus])
  @@index([autoApproveAt, approvalStatus])
}

model JobTaskAttachment {
  id               String    @id @default(cuid())
  taskId           String
  uploadedByUserId String?
  mediaType        MediaType @default(PHOTO)
  kind             String
  url              String    @db.Text
  s3Key            String
  label            String?
  createdAt        DateTime  @default(now())

  task       JobTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("JobTaskAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([taskId, kind])
}

model JobTaskEvent {
  id          String   @id @default(cuid())
  taskId      String
  actorUserId String?
  action      String
  note        String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  task  JobTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User?   @relation("JobTaskEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

// ─────────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  sku       String?  @unique
  category  String
  location  String   @default("CLEANERS_CUPBOARD")
  unit      String   @default("unit")
  supplier  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertyStocks   PropertyStock[]
  shoppingRunLines ShoppingRunLine[]
  heldStocks       HeldStock[]
}

model PropertyStock {
  id               String   @id @default(cuid())
  propertyId       String
  itemId           String
  onHand           Float    @default(0)
  parLevel         Float    @default(0)
  reorderThreshold Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property      Property       @relation(fields: [propertyId], references: [id])
  item          InventoryItem  @relation(fields: [itemId], references: [id])
  transactions  StockTx[]
  stockRunLines StockRunLine[]

  @@unique([propertyId, itemId])
}

model StockTx {
  id              String      @id @default(cuid())
  propertyStockId String
  submissionId    String?
  txType          StockTxType
  quantity        Float // positive = add, negative = deduct
  notes           String?
  createdAt       DateTime    @default(now())

  propertyStock PropertyStock   @relation(fields: [propertyStockId], references: [id])
  submission    FormSubmission? @relation(fields: [submissionId], references: [id])
}

/// On-hand stock ledger: stock that has been bought/shopped and is physically
/// held by someone (a cleaner, client, or QA inspector) but NOT yet delivered to
/// a unit. The holder can drop portions to one or more properties over time;
/// each delivery decrements `quantity` and is recorded as a HeldStockDelivery
/// (which also bumps the unit's PropertyStock.onHand).
model HeldStock {
  id           String          @id @default(cuid())
  itemId       String
  holderUserId String
  quantity     Float           @default(0) // remaining quantity still on hand
  originalQty  Float           @default(0) // quantity originally acquired
  unitCostAud  Float?
  status       HeldStockStatus @default(HELD)
  shoppingRunId String? // optional link to the shopping run it came from
  sourceNote   String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  item       InventoryItem       @relation(fields: [itemId], references: [id])
  holder     User                @relation("HeldStockHolder", fields: [holderUserId], references: [id])
  deliveries HeldStockDelivery[]

  @@index([holderUserId, status])
  @@index([itemId, status])
}

/// A drop of held stock to a specific unit. Decrements HeldStock.quantity and
/// increments the property's PropertyStock.onHand (with a StockTx audit row).
model HeldStockDelivery {
  id            String   @id @default(cuid())
  heldStockId   String
  propertyId    String
  quantity      Float
  deliveredById String
  note          String?  @db.Text
  createdAt     DateTime @default(now())

  heldStock   HeldStock @relation(fields: [heldStockId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id])
  deliveredBy User      @relation("HeldStockDeliveredBy", fields: [deliveredById], references: [id])

  @@index([propertyId, createdAt])
  @@index([heldStockId])
}

// ─────────────────────────────────────────────
// Laundry
// ─────────────────────────────────────────────

model LaundryTask {
  id                String        @id @default(cuid())
  jobId             String        @unique
  propertyId        String
  pickupDate        DateTime // UTC date
  dropoffDate       DateTime // UTC date
  status            LaundryStatus @default(PENDING)
  flagReason        LaundryFlag?
  flagNotes         String?
  confirmedAt       DateTime?
  pickedUpAt        DateTime?
  droppedAt         DateTime?
  notifyLaundry     Boolean       @default(false)
  noPickupRequired  Boolean       @default(false)
  skipReasonCode    String?
  skipReasonNote    String?       @db.Text
  adminOverrideNote String?       @db.Text
  adminOverrideById String?
  adminOverrideAt   DateTime?
  bagWeightKg       Float?
  dropoffCostAud    Float?
  receiptImageUrl   String?
  // Key-handling evidence: photo of the key at pickup + when returned at drop-off.
  pickupKeyPhotoUrl  String?
  dropoffKeyPhotoUrl String?
  supplierId        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  job           Job                   @relation(fields: [jobId], references: [id])
  property      Property              @relation(fields: [propertyId], references: [id])
  supplier      LaundrySupplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
