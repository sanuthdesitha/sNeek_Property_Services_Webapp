// ─────────────────────────────────────────────
// Auth (NextAuth v4 compatible)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// A registered WebAuthn / passkey authenticator (platform biometric:
/// fingerprint on Android, Face ID / Touch ID on iOS, Windows Hello). Lets a
/// user sign in on a trusted device without a password. credentialId/publicKey
/// are base64url strings; counter guards against cloned-authenticator replay.
model WebAuthnCredential {
  id            String    @id @default(cuid())
  userId        String
  credentialId  String    @unique
  publicKey     String    @db.Text
  counter       BigInt    @default(0)
  transports    String?
  deviceType    String?
  backedUp      Boolean   @default(false)
  deviceName    String?
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// How a user receives their second-factor code.
enum TwoFactorMethod {
  TOTP  // authenticator app (Google Authenticator / Authy)
  EMAIL // one-time code emailed at sign-in
}

/// A device the user chose to "remember", so 2FA isn't prompted again on it for
/// the cookie's lifetime. We store only a SHA-256 hash of the random token; the
/// raw token lives in an httpOnly cookie on the device.
model TrustedDevice {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  label      String?
  userAgent  String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// A browser/PWA Web Push subscription (VAPID). Lets us deliver real push
/// notifications (WhatsApp-style) to a user's device for the "web" channel,
/// not just email. endpoint is the unique push service URL; p256dh/auth are
/// the subscription's encryption keys.
model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  endpoint   String    @unique @db.Text
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// An item on a property that needs maintenance, repair, or replacement —
/// outdated/worn/broken things that hurt the guest experience, appearance, or
/// quality. Reported by cleaners, clients, or QA inspectors (and admins), and
/// worked down to resolution. Scoped to Airbnb-style properties in app logic.
model PropertyMaintenanceItem {
  id               String                  @id @default(cuid())
  propertyId       String
  jobId            String?
  reportedByUserId String
  source           MaintenanceSource
  category         MaintenanceCategory     @default(OTHER)
  area             String?
  title            String
  description      String?                 @db.Text
  recommendedAction MaintenanceAction      @default(REPLACE)
  priority         MaintenancePriority     @default(MEDIUM)
  status           MaintenanceStatus       @default(OPEN)
  photoKeys        Json?
  estimatedCost    Float?
  // Client-facing cost quote + approval (Phase 3 of the client maintenance epic).
  quotedCost          Float?
  costApprovalStatus  String? // null | PENDING | APPROVED | DECLINED
  costDecidedAt       DateTime?
  clientVisible    Boolean                 @default(true)
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolutionNote   String?                 @db.Text

  // ── Assignment + worker visit lifecycle ──
  assignedWorkerId    String?
  assignedAt          DateTime?
  assignedByUserId    String?
  scheduledFor        DateTime?
  shareAccess         Boolean             @default(false) // expose property access details to the worker
  contactPersonUserId String? // person-in-charge the worker can call/email/sms
  enRouteAt           DateTime?
  arrivedAt           DateTime?
  workStartedAt       DateTime?
  clockInAt           DateTime?
  clockOutAt          DateTime?
  outcome             MaintenanceOutcome?
  workerNote          String?             @db.Text
  issuesNote          String?             @db.Text
  finishPhotoKeys     Json?

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  property       Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  job            Job?                       @relation(fields: [jobId], references: [id], onDelete: SetNull)
  reportedBy     User                       @relation("MaintenanceReportedBy", fields: [reportedByUserId], references: [id])
  resolvedBy     User?                      @relation("MaintenanceResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  assignedWorker MaintenanceWorker?         @relation("MaintenanceAssignedWorker", fields: [assignedWorkerId], references: [id], onDelete: SetNull)
  assignedBy     User?                      @relation("MaintenanceAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  contactPerson  User?                      @relation("MaintenanceContactPerson", fields: [contactPersonUserId], references: [id], onDelete: SetNull)
  events         PropertyMaintenanceEvent[]
  pings          MaintenanceLocationPing[]

  @@index([propertyId, status])
  @@index([status, priority])
  @@index([reportedByUserId])
  @@index([assignedWorkerId, status])
}

/// A maintenance/repair person. May be ad-hoc (no portal login) or permanent
/// (linked to a MAINTENANCE-role User the admin created with one click).
model MaintenanceWorker {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  email       String?
  trade       String? // Plumber / Electrician / Handyman / etc.
  company     String?
  isPermanent Boolean   @default(false)
  isActive    Boolean   @default(true)
  notes       String?   @db.Text
  userId      String?   @unique // portal User (role MAINTENANCE) when permanent
  createdById String?
  onboardedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?                     @relation("MaintenanceWorkerUser", fields: [userId], references: [id], onDelete: SetNull)
  createdBy   User?                     @relation("MaintenanceWorkerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignments PropertyMaintenanceItem[] @relation("MaintenanceAssignedWorker")
  pings       MaintenanceLocationPing[]

  @@index([isActive, isPermanent])
}

/// GPS breadcrumb for a maintenance visit (en route → arrived → clock in/out).
model MaintenanceLocationPing {
  id        String              @id @default(cuid())
  itemId    String
  workerId  String?
  lat       Float
  lng       Float
  accuracy  Float?
  kind      MaintenancePingKind @default(PING)
  createdAt DateTime            @default(now())

  item   PropertyMaintenanceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  worker MaintenanceWorker?      @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
}

/// Lifecycle/audit trail for a maintenance item (status changes, notes), so the
/// list stays automatically tracked over time.
model PropertyMaintenanceEvent {
  id         String            @id @default(cuid())
  itemId     String
  userId     String?
  fromStatus MaintenanceStatus?
  toStatus   MaintenanceStatus
  note       String?           @db.Text
  createdAt  DateTime          @default(now())

  item PropertyMaintenanceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User?                   @relation("MaintenanceEventBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
}

