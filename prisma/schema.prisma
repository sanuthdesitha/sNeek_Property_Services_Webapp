model UserInvitation {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String?
  createdBy   User?     @relation("UserInvitationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CLEANER)
  phone         String?
  hourlyRate    Float?
  isActive      Boolean   @default(true)

  // Optional two-factor authentication (per-user opt-in).
  twoFactorEnabled     Boolean          @default(false)
  twoFactorMethod      TwoFactorMethod?
  totpSecret           String?          // base32 secret (TOTP method only)
  twoFactorBackupCodes String?          // JSON array of sha256-hashed one-time codes

  profileEditingEnabled Boolean @default(true)
  bankBsb           String?
  bankAccountNumber   String?
  bankAccountName     String?
  stripeAccountId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                     Account[]
  sessions                     Session[]
  jobAssignments               JobAssignment[]
  timeLogs                     TimeLog[]
  formSubmissions              FormSubmission[]
  qaAssignmentsAssigned        QaAssignment[]              @relation("QaAssignmentAssignedTo")
  qaAssignmentsCreated         QaAssignment[]              @relation("QaAssignmentCreatedBy")
  qaAssignmentsPickedUp        QaAssignment[]              @relation("QaAssignmentPickedUpBy")
  qaFormSubmissions            QaFormSubmission[]          @relation("QaFormSubmissionSubmittedBy")
  qaReviews                    QAReview[]                  @relation("QAReviewReviewedBy")
  qaReworkAsQa                 QaReworkTransfer[]          @relation("QaReworkQa")
  qaReworkAsCleaner            QaReworkTransfer[]          @relation("QaReworkCleaner")
  qaReworkReviewed             QaReworkTransfer[]          @relation("QaReworkReviewedBy")
  webauthnCredentials          WebAuthnCredential[]
  trustedDevices               TrustedDevice[]
  pushSubscriptions            PushSubscription[]
  maintenanceReported          PropertyMaintenanceItem[]   @relation("MaintenanceReportedBy")
  maintenanceResolved          PropertyMaintenanceItem[]   @relation("MaintenanceResolvedBy")
  maintenanceEvents            PropertyMaintenanceEvent[]  @relation("MaintenanceEventBy")
  maintenanceAssigned          PropertyMaintenanceItem[]   @relation("MaintenanceAssignedBy")
  maintenanceContactFor        PropertyMaintenanceItem[]   @relation("MaintenanceContactPerson")
  maintenanceWorker            MaintenanceWorker?          @relation("MaintenanceWorkerUser")
  maintenanceWorkersCreated    MaintenanceWorker[]         @relation("MaintenanceWorkerCreatedBy")
  mediaOverrideRequests        MediaOverrideRequest[]      @relation("MediaOverrideRequestedBy")
  mediaOverrideDecisions       MediaOverrideRequest[]      @relation("MediaOverrideDecidedBy")
  auditLogs                    AuditLog[]                  @relation("AuditUser")
  notifications                Notification[]
  notificationPreference       UserNotificationPreference?
  pushDevices                  UserPushDevice[]
  payAdjustmentRequests        CleanerPayAdjustment[]      @relation("CleanerAdjustmentRequests")
  payAdjustmentReviews         CleanerPayAdjustment[]      @relation("CleanerAdjustmentReviews")
  timeAdjustmentRequests       TimeLogAdjustmentRequest[]  @relation("TimeAdjustmentRequestedBy")
  timeAdjustmentReviews        TimeLogAdjustmentRequest[]  @relation("TimeAdjustmentReviewedBy")
  icalSyncRunsTriggered        IcalSyncRun[]               @relation("IcalSyncTriggeredBy")
  icalSyncRunsReverted         IcalSyncRun[]               @relation("IcalSyncRevertedBy")
  assignedCases                IssueTicket[]               @relation("IssueTicketAssignedTo")
  caseComments                 CaseComment[]
  payrollRunsCreated           PayrollRun[]                @relation("PayrollRunCreatedBy")
  payouts                      Payout[]                    @relation("CleanerPayouts")
  caseAttachments              CaseAttachment[]
  stockRuns                    StockRun[]                  @relation("StockRunRequestedBy")
  heldStocks                   HeldStock[]                 @relation("HeldStockHolder")
  heldStockDeliveries          HeldStockDelivery[]         @relation("HeldStockDeliveredBy")
  shoppingRuns                 ShoppingRun[]               @relation("ShoppingRunOwner")
  shoppingReceipts             ShoppingReceipt[]           @relation("ShoppingReceiptUploadedBy")
  shoppingSettlementsPaid      ShoppingSettlement[]        @relation("ShoppingSettlementPaidBy")
  reportVisibilityUpdates      Report[]                    @relation("ReportVisibilityUpdatedBy")
  // Client link (optional)
  clientId                     String?
  client                       Client?                     @relation(fields: [clientId], references: [id])
  createdTeamGroups            TeamGroup[]                 @relation("TeamGroupCreatedBy")
  teamGroupMemberships         TeamGroupMember[]           @relation("TeamGroupMembershipUser")
  createdWorkforcePosts        WorkforcePost[]             @relation("WorkforcePostCreatedBy")
  workforcePostReads           WorkforcePostRead[]         @relation("WorkforcePostReadUser")
  createdChatChannels          ChatChannel[]               @relation("ChatChannelCreatedBy")
  chatChannelReads             ChatChannelRead[]           @relation("ChatChannelReadUser")
  sentChatMessages             ChatMessage[]               @relation("ChatMessageSender")
  learningPathsCreated         LearningPath[]              @relation("LearningPathCreatedBy")
  learningAssignments          LearningAssignment[]        @relation("LearningAssignmentUser")
  staffDocuments               StaffDocument[]             @relation("StaffDocumentOwner")
  uploadedStaffDocuments       StaffDocument[]             @relation("StaffDocumentUploadedBy")
  verifiedStaffDocuments       StaffDocument[]             @relation("StaffDocumentVerifiedBy")
  requestedStaffDocuments      StaffDocumentRequest[]      @relation("StaffDocumentRequestUser")
  createdStaffDocumentRequests StaffDocumentRequest[]      @relation("StaffDocumentRequestCreatedBy")
  sentRecognitions             StaffRecognition[]          @relation("RecognitionSentBy")
  receivedRecognitions         StaffRecognition[]          @relation("RecognitionReceivedBy")
  createdHiringPositions       HiringPosition[]            @relation("HiringPositionCreatedBy")
  reviewedHiringApplications   HiringApplication[]         @relation("HiringApplicationReviewedBy")
  hiredFromApplications        HiringApplication[]         @relation("HiringApplicationHiredUser")
  hiringEventsActed            HiringApplicationEvent[]    @relation("HiringEventActor")
  requestedJobTasks            JobTask[]                   @relation("JobTaskRequestedBy")
