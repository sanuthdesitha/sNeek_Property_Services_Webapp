// sNeek Ops Dashboard — Prisma schema v2 (Next-Gen)
// Timezone: Australia/Sydney (stored as UTC, displayed via date-fns-tz)
// All existing models preserved exactly. New models added for multi-tenancy, onboarding, partners.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  OPS_MANAGER
  CLEANER
  CLIENT
  LAUNDRY
}

enum JobType {
  AIRBNB_TURNOVER
  DEEP_CLEAN
  END_OF_LEASE
  GENERAL_CLEAN
  POST_CONSTRUCTION
  PRESSURE_WASH
  WINDOW_CLEAN
  LAWN_MOWING
  SPECIAL_CLEAN
  COMMERCIAL_RECURRING
  CARPET_STEAM_CLEAN
  MOLD_TREATMENT
  UPHOLSTERY_CLEANING
  TILE_GROUT_CLEANING
  GUTTER_CLEANING
  SPRING_CLEANING
}

enum JobStatus {
  UNASSIGNED
  OFFERED
  ASSIGNED
  EN_ROUTE
  IN_PROGRESS
  PAUSED
  WAITING_CONTINUATION_APPROVAL
  SUBMITTED
  QA_REVIEW
  COMPLETED
  INVOICED
}

enum JobAssignmentResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
  TRANSFERRED
}

enum LaundryStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  DROPPED
  FLAGGED
  SKIPPED_PICKUP
}

enum LaundryFlag {
  NO_WINDOW
  BUFFER_REQUIRED
  EXPRESS_OR_EXTRA_LINEN_REQUIRED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum StockTxType {
  USED
  RESTOCKED
  ADJUSTED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  CONVERTED
}

enum PayAdjustmentType {
  HOURLY
  FIXED
}

enum PayAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayAdjustmentScope {
  JOB
  PROPERTY
  STANDALONE
}

enum TimeAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED
  LOST
}

enum IntegrationProvider {
  ICAL_HOSPITABLE
  ICAL_OTHER
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  ERROR
}

enum LaundryOutcome {
  READY_FOR_PICKUP
  NOT_READY
  NO_PICKUP_REQUIRED
}

enum ShoppingRunStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  APPROVED
  BILLED
  REIMBURSED
  CLOSED
}

enum ShoppingPaymentMethod {
  COMPANY_CARD
  CLIENT_CARD
  CLEANER_CARD
  ADMIN_CARD
  CASH
  BANK_TRANSFER
  OTHER
}

enum ShoppingPaidByScope {
  COMPANY
  CLIENT
  CLEANER
  ADMIN
  OTHER
}

enum StockRunStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  APPLIED
  DISCARDED
}

enum ClientInvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PAID
  VOID
}

enum JobTaskSource {
  ADMIN
  CLIENT
  CARRY_FORWARD
}

enum JobTaskApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  AUTO_APPROVED
}

enum JobTaskExecutionStatus {
  OPEN
  COMPLETED
  NOT_COMPLETED
  CARRIED_FORWARD
  CANCELLED
}

enum PayrollRunStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  COMPLETED
  FAILED
  VOID
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PayoutMethod {
  STRIPE_CONNECT
  ABA_FILE
  MANUAL_BANK_TRANSFER
}

enum GatewayProvider {
  STRIPE
  PAYPAL
  SQUARE
}

enum GatewayStatus {
  ACTIVE
  INACTIVE
  TEST
}

enum NotificationRecipientRole {
  ADMIN
  CLEANER
  CLIENT
}

enum NotificationLogStatus {
  SENT
  FAILED
  SKIPPED
}

// ── New Enums ──

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum PartnerType {
  LAUNDRY
  SUPPLY
  MAINTENANCE
  SPECIALTY
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PartnerJobStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum OnboardingItemType {
  CLIENT
  PROPERTY
  INTEGRATION
  FORM_TEMPLATE
  PRICE_BOOK_ENTRY
  PROPERTY_CLIENT_RATE
  JOB_SCHEDULE
  JOB
  INVENTORY_DEFAULT
  LAUNDRY_SETTING
}

enum OnboardingItemStatus {
  PENDING
  APPROVED
  EDITED
  REJECTED
}

enum SurveySectionKey {
  CLIENT
  PROPERTY
  APPLIANCES
  SPECIAL_REQUESTS
  LAUNDRY
  ACCESS
  TIMING
  TEAM
  SERVICES
  ICAL
  PRICING
}

// ─────────────────────────────────────────────
// Auth (NextAuth v5 compatible)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Multi-Tenant
// ─────────────────────────────────────────────

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  plan       TenantPlan   @default(FREE)
  status     TenantStatus @default(TRIAL)
  settings   Json?
  trialEnds  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  users          User[]
  clients        Client[]
  properties     Property[]
  jobs           Job[]
  partners       Partner[]
  featureFlags   FeatureFlag[]
  tenantSettings TenantSetting[]
  usageRecords   UsageRecord[]
  subscriptions  Subscription[]
  billingInvoices BillingInvoice[]
  surveys         PropertySurvey[]
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  key         String
  enabled     Boolean  @default(false)
  rolloutPct  Float    @default(100)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model Subscription {
  id            String   @id @default(cuid())
  tenantId      String
  plan          String
  billingCycle  String   // MONTHLY, ANNUAL
  status        String   @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id          String   @id @default(cuid())
  tenantId    String
  metric      String   // jobs_created, cleaners_active, properties_managed
  quantity    Int      @default(1)
  recordedAt  DateTime @default(now())
  metadata    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, metric, recordedAt])
}

model BillingInvoice {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceNumber String   @unique
  amount        Float
  currency      String   @default("AUD")
  status        String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, VOID
  periodStart   DateTime
  periodEnd     DateTime
  lineItems     Json
  dueDate       DateTime
  paidAt        DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments BillingPayment[]
}

model BillingPayment {
  id               String   @id @default(cuid())
  billingInvoiceId String
  amount           Float
  currency         String   @default("AUD")
  method           String   // STRIPE, BANK_TRANSFER, MANUAL
  status           String   @default("PENDING")
  gatewayPaymentId String?
  paidAt           DateTime?
  metadata         Json?
  createdAt        DateTime @default(now())

  billingInvoice BillingInvoice @relation(fields: [billingInvoiceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CLEANER)
  phone         String?
  hourlyRate    Float?
  isActive      Boolean   @default(true)
  bankBsb           String?
  bankAccountNumber   String?
  bankAccountName     String?
  stripeAccountId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant                     Tenant?                    @relation(fields: [tenantId], references: [id])
  accounts                     Account[]
  sessions                     Session[]
  jobAssignments               JobAssignment[]
  timeLogs                     TimeLog[]
  formSubmissions              FormSubmission[]
  auditLogs                    AuditLog[]                  @relation("AuditUser")
  notifications                Notification[]
  notificationPreference       UserNotificationPreference?
  pushDevices                  UserPushDevice[]
  payAdjustmentRequests        CleanerPayAdjustment[]      @relation("CleanerAdjustmentRequests")
  payAdjustmentReviews         CleanerPayAdjustment[]      @relation("CleanerAdjustmentReviews")
  timeAdjustmentRequests       TimeLogAdjustmentRequest[]  @relation("TimeAdjustmentRequestedBy")
  timeAdjustmentReviews        TimeLogAdjustmentRequest[]  @relation("TimeAdjustmentReviewedBy")
  icalSyncRunsTriggered        IcalSyncRun[]               @relation("IcalSyncTriggeredBy")
  icalSyncRunsReverted         IcalSyncRun[]               @relation("IcalSyncRevertedBy")
  assignedCases                IssueTicket[]               @relation("IssueTicketAssignedTo")
  caseComments                 CaseComment[]
  payrollRunsCreated           PayrollRun[]                @relation("PayrollRunCreatedBy")
  payouts                      Payout[]                    @relation("CleanerPayouts")
  caseAttachments              CaseAttachment[]
  stockRuns                    StockRun[]                  @relation("StockRunRequestedBy")
  shoppingRuns                 ShoppingRun[]               @relation("ShoppingRunOwner")
  shoppingReceipts             ShoppingReceipt[]           @relation("ShoppingReceiptUploadedBy")
  shoppingSettlementsPaid      ShoppingSettlement[]        @relation("ShoppingSettlementPaidBy")
  reportVisibilityUpdates      Report[]                    @relation("ReportVisibilityUpdatedBy")
  // Client link (optional)
  clientId                     String?
  client                       Client?                     @relation(fields: [clientId], references: [id])
  createdTeamGroups            TeamGroup[]                 @relation("TeamGroupCreatedBy")
  teamGroupMemberships         TeamGroupMember[]           @relation("TeamGroupMembershipUser")
  createdWorkforcePosts        WorkforcePost[]             @relation("WorkforcePostCreatedBy")
  workforcePostReads           WorkforcePostRead[]         @relation("WorkforcePostReadUser")
  createdChatChannels          ChatChannel[]               @relation("ChatChannelCreatedBy")
  chatChannelReads             ChatChannelRead[]           @relation("ChatChannelReadUser")
  sentChatMessages             ChatMessage[]               @relation("ChatMessageSender")
  learningPathsCreated         LearningPath[]              @relation("LearningPathCreatedBy")
  learningAssignments          LearningAssignment[]        @relation("LearningAssignmentUser")
  staffDocuments               StaffDocument[]             @relation("StaffDocumentOwner")
  uploadedStaffDocuments       StaffDocument[]             @relation("StaffDocumentUploadedBy")
  verifiedStaffDocuments       StaffDocument[]             @relation("StaffDocumentVerifiedBy")
  requestedStaffDocuments      StaffDocumentRequest[]      @relation("StaffDocumentRequestUser")
  createdStaffDocumentRequests StaffDocumentRequest[]      @relation("StaffDocumentRequestCreatedBy")
  sentRecognitions             StaffRecognition[]          @relation("RecognitionSentBy")
  receivedRecognitions         StaffRecognition[]          @relation("RecognitionReceivedBy")
  createdHiringPositions       HiringPosition[]            @relation("HiringPositionCreatedBy")
  reviewedHiringApplications   HiringApplication[]         @relation("HiringApplicationReviewedBy")
  hiredFromApplications        HiringApplication[]         @relation("HiringApplicationHiredUser")
  requestedJobTasks            JobTask[]                   @relation("JobTaskRequestedBy")
  approvedJobTasks             JobTask[]                   @relation("JobTaskApprovedBy")
  uploadedJobTaskAttachments   JobTaskAttachment[]         @relation("JobTaskAttachmentUploadedBy")
  jobTaskEvents                JobTaskEvent[]              @relation("JobTaskEventActor")
  sentClientMessages           ClientMessage[]             @relation("ClientMessageSender")
  cleanerAvailabilityEntries   CleanerAvailability[]       @relation("CleanerAvailabilityUser")
  preferredForProperties       Property[]                  @relation("PropertyPreferredCleaner")
  createdEmailCampaigns        EmailCampaign[]             @relation("EmailCampaignCreatedBy")
  cleanerLocationPings         CleanerLocationPing[]
  // Onboarding
  surveysConducted             PropertySurvey[]            @relation("SurveyConductedBy")
  approvalsPerformed         OnboardingApprovalLog[]       @relation("OnboardingApprovalBy")

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// Clients + Properties
// ─────────────────────────────────────────────

model Client {
  id                        String   @id @default(cuid())
  tenantId                  String?
  name                      String
  email                     String?
  phone                     String?
  address                   String?
  notes                     String?  @db.Text
  portalVisibilityOverrides Json?
  isActive                  Boolean  @default(true)
  xeroContactId             String?
  xeroSyncedAt              DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant                   Tenant?                    @relation(fields: [tenantId], references: [id])
  properties               Property[]
  users                    User[]
  quotes                   Quote[]
  jobTasks                 JobTask[]
  leads                    QuoteLead[]
  cases                    IssueTicket[]
  shoppingRuns             ShoppingRun[]
  invoices                 ClientInvoice[]
  loyaltyAccount           LoyaltyAccount?
  referralsMade            Referral[]                 @relation("ReferralReferrer")
  referralsConverted       Referral[]                 @relation("ReferralReferee")
  satisfactionRatings      ClientSatisfactionRating[]
  messages                 ClientMessage[]
  notificationPref         ClientNotificationPreference?
  automationRules          ClientAutomationRule[]
  jobFeedback              JobFeedback[]
  lastReviewRequestSentAt  DateTime?
  surveys                  PropertySurvey[]

  @@index([tenantId])
}

model Property {
  id                     String   @id @default(cuid())
  tenantId               String?
  clientId               String
  name                   String
  address                String
  suburb                 String
  state                  String   @default("NSW")
  postcode               String?
  notes                  String?  @db.Text
  accessInfo             Json? // { lockbox, codes, parking, other }
  linenBufferSets        Int      @default(0)
  inventoryEnabled       Boolean  @default(false)
  defaultCheckinTime     String   @default("14:00") // HH:mm
  defaultCheckoutTime    String   @default("10:00") // HH:mm
  hasBalcony             Boolean  @default(false)
  bedrooms               Int      @default(1)
  bathrooms              Int      @default(1)
  latitude               Float?
  longitude              Float?
  accessCode             String?  @db.Text
  alarmCode              String?  @db.Text
  keyLocation            String?
  accessNotes            String?  @db.Text
  preferredCleanerUserId     String?
  showCleanerContactToClient Boolean  @default(false)
  laundryEnabled             Boolean  @default(true)
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant           Tenant?                @relation(fields: [tenantId], references: [id])
  client           Client                 @relation(fields: [clientId], references: [id])
  preferredCleaner User?                  @relation("PropertyPreferredCleaner", fields: [preferredCleanerUserId], references: [id])
  integration      Integration?
  reservations     Reservation[]
  jobs             Job[]
  propertyStock    PropertyStock[]
  laundryTasks     LaundryTask[]
  icalSyncRuns     IcalSyncRun[]
  cases            IssueTicket[]
  stockRuns        StockRun[]
  shoppingRunLines ShoppingRunLine[]
  clientRates      PropertyClientRate[]
  payAdjustments   CleanerPayAdjustment[]
  jobTasks         JobTask[]

  @@index([tenantId])
}

model Integration {
  id               String              @id @default(cuid())
  propertyId       String              @unique
  provider         IntegrationProvider @default(ICAL_HOSPITABLE)
  icalUrl          String?             @db.Text
  isEnabled        Boolean             @default(false)
  lastSyncAt       DateTime?
  lastSyncEtag     String?
  lastSyncModified String?
  syncStatus       SyncStatus          @default(IDLE)
  syncError        String?             @db.Text
  notes            String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  property Property      @relation(fields: [propertyId], references: [id])
  syncRuns IcalSyncRun[]
}

model IcalSyncRun {
  id            String    @id @default(cuid())
  integrationId String
  propertyId    String
  triggeredById String?
  revertedById  String?
  mode          String    @default("MANUAL")
  status        String    @default("RUNNING")
  summary       Json?
  snapshot      Json?
  error         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  revertedAt    DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation("IcalSyncTriggeredBy", fields: [triggeredById], references: [id])
  revertedBy  User?       @relation("IcalSyncRevertedBy", fields: [revertedById], references: [id])

  @@index([integrationId, createdAt])
  @@index([propertyId, createdAt])
}

model Reservation {
  id              String    @id @default(cuid())
  propertyId      String
  uid             String // iCal UID
  startDate       DateTime // check-in (UTC)
  endDate         DateTime // check-out (UTC)
  summary         String?
  guestName       String?
  reservationCode String?
  guestPhone      String?
  guestEmail      String?
  guestProfileUrl String?   @db.Text
  adults          Int?
  children        Int?
  infants         Int?
  locationText    String?   @db.Text
  geoLat          Float?
  geoLng          Float?
  checkinAtLocal  DateTime?
  checkoutAtLocal DateTime?
  source          String?   @default("ical")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  job      Job?

  @@unique([propertyId, uid])
}

// ─────────────────────────────────────────────
// Jobs
// ─────────────────────────────────────────────

model Job {
  id                    String    @id @default(cuid())
  tenantId              String?
  jobNumber             String    @unique
  propertyId            String
  reservationId         String?   @unique
  jobType               JobType
  status                JobStatus @default(UNASSIGNED)
  scheduledDate         DateTime // date of cleaning (UTC start of day)
  startTime             String? // HH:mm (property local)
  endTime               String? // HH:mm (property local)
  dueTime               String? // latest completion HH:mm
  estimatedHours        Float?
  actualHours           Float?
  notes                 String?   @db.Text
  internalNotes         String?   @db.Text
  priorityBucket        Int       @default(4)
  priorityReason        String?
  sameDayCheckin        Boolean   @default(false)
  sameDayCheckinTime    String?
  reminder24hSent       Boolean   @default(false)
  reminder2hSent        Boolean   @default(false)
  gpsCheckInLat         Float?
  gpsCheckInLng         Float?
  gpsCheckInAt          DateTime?
  gpsCheckOutLat        Float?
  gpsCheckOutLng        Float?
  gpsCheckOutAt         DateTime?
  gpsDistanceMeters      Int?
  requiresSafetyCheckin  Boolean   @default(false)
  safetyCheckinAt        DateTime?
  manuallyRescheduledAt   DateTime?
  rescheduledBy           String?
  enRouteStartedAt        DateTime?
  enRouteEtaMinutes       Int?
  enRouteEtaUpdatedAt     DateTime?
  drivingPausedAt         DateTime?
  drivingPauseReason      String?
  drivingDelayedAt        DateTime?
  drivingDelayedReason    String?
  arrivedAt               DateTime?
  lastEtaNotificationAt   DateTime?
  lastEtaNotifiedMinutes  Int?
  lastDelayedNotificationAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant                 Tenant?                  @relation(fields: [tenantId], references: [id])
  property               Property                   @relation(fields: [propertyId], references: [id])
  reservation            Reservation?               @relation(fields: [reservationId], references: [id])
  assignments            JobAssignment[]
  timeLogs               TimeLog[]
  formSubmissions        FormSubmission[]
  qaReviews              QAReview[]
  laundryTask            LaundryTask?
  report                 Report?
  issueTickets           IssueTicket[]
  payAdjustments         CleanerPayAdjustment[]
  timeAdjustmentRequests TimeLogAdjustmentRequest[]
  auditLogs              AuditLog[]                 @relation("AuditJob")
  invoiceLines           ClientInvoiceLine[]
  jobTasks               JobTask[]
  satisfactionRating     ClientSatisfactionRating?
  cleanerLocationPings   CleanerLocationPing[]
  feedback               JobFeedback?

  @@index([tenantId])
}

model CleanerPayAdjustment {
  id              String              @id @default(cuid())
  jobId           String?
  propertyId      String?
  cleanerId       String
  scope           PayAdjustmentScope  @default(JOB)
  title           String?
  type            PayAdjustmentType
  requestedHours  Float?
  requestedRate   Float?
  requestedAmount Float
  approvedAmount  Float?
  status          PayAdjustmentStatus @default(PENDING)
  cleanerNote     String?             @db.Text
  attachmentKeys  Json?
  adminNote       String?             @db.Text
  requestedAt     DateTime            @default(now())
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  job        Job?      @relation(fields: [jobId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
  cleaner    User      @relation("CleanerAdjustmentRequests", fields: [cleanerId], references: [id])
  reviewedBy User?     @relation("CleanerAdjustmentReviews", fields: [reviewedById], references: [id])

  @@index([cleanerId, status])
  @@index([jobId, status])
  @@index([propertyId, status])
}

model JobAssignment {
  id                       String                      @id @default(cuid())
  jobId                    String
  userId                   String
  isPrimary                Boolean                     @default(false)
  payRate                  Float?
  assignedAt               DateTime                    @default(now())
  offeredAt                DateTime                    @default(now())
  removedAt                DateTime?
  responseStatus           JobAssignmentResponseStatus @default(PENDING)
  respondedAt              DateTime?
  responseNote             String?                     @db.Text
  assignedById             String?
  transferredFromUserId    String?

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

model TimeLog {
  id        String    @id @default(cuid())
  jobId     String
  userId    String
  startedAt DateTime
  stoppedAt DateTime?
  durationM Int?
  notes     String?

  job                Job                        @relation(fields: [jobId], references: [id])
  user               User                       @relation(fields: [userId], references: [id])
  adjustmentRequests TimeLogAdjustmentRequest[]
}

model TimeLogAdjustmentRequest {
  id                 String               @id @default(cuid())
  timeLogId          String
  jobId              String
  cleanerId          String
  requestedDurationM Int
  requestedStoppedAt DateTime?
  originalDurationM  Int
  originalStoppedAt  DateTime?
  reason             String?              @db.Text
  status             TimeAdjustmentStatus @default(PENDING)
  reviewedById       String?
  reviewedAt         DateTime?
  adminNote          String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  timeLog    TimeLog @relation(fields: [timeLogId], references: [id], onDelete: Cascade)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cleaner    User    @relation("TimeAdjustmentRequestedBy", fields: [cleanerId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("TimeAdjustmentReviewedBy", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([jobId, status])
  @@index([cleanerId, status])
}

