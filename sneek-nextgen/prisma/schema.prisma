  entityType  String
  entityId    String
  localData   Json
  serverData  Json
  resolvedBy  String?  // MANUAL, LOCAL_WINS, SERVER_WINS
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────
// NEW: Usage Plans (for usage-based billing)
// ─────────────────────────────────────────────

model UsagePlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  pricing     Json     // { per_job: Float, per_cleaner: Float, per_property: Float }
  limits      Json?    // { max_jobs: Int, max_cleaners: Int, max_properties: Int }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeatureAccess {
  id          String   @id @default(cuid())
  planTier    String   // FREE, PRO, ENTERPRISE
  featureKey  String
  enabled     Boolean  @default(false)
  limit       Int?
  createdAt   DateTime @default(now())

  @@unique([planTier, featureKey])
}
