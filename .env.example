# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sneek_ops"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# S3 / Cloudflare R2
S3_BUCKET_NAME="sneek-uploads"
S3_REGION="auto"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_PUBLIC_BASE_URL="https://pub-<hash>.r2.dev"

# Email – Resend
RESEND_API_KEY="re_xxxxxx"
EMAIL_FROM="noreply@sneekops.com.au"

# SMS – Twilio (optional)
TWILIO_ACCOUNT_SID="ACxxxx"
TWILIO_AUTH_TOKEN="xxxx"
TWILIO_PHONE_NUMBER="+61400000000"

# App
# Preferred public base URL used in emails and share links (domain or IP)
APP_BASE_URL="https://app.sneekproservices.com.au"
APP_URL="http://localhost:3000"
TZ="Australia/Sydney"
VIDEO_MAX_UPLOAD_MB="300"
