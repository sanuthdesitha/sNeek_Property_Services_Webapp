# Production environment template for https://sneekholdings.com
# Copy this to `.env` on the server and fill in the real secrets there.

# Database
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/sneek_ops?schema=public"
DIRECT_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/sneek_ops?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://sneekholdings.com"

# Optional admin bootstrap on build/deploy
# If these are set, `npm run setup:runtime` will ensure the admin account exists.
BOOTSTRAP_ADMIN_EMAIL="admin@sneekproservices.com.au"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
BOOTSTRAP_ADMIN_NAME="Admin User"

# Optional build-time toggles
# Leave these off for remote/container builds that cannot reach the live database.
# Set to 1 only when your build environment can access those services directly.
RUN_DB_DEPLOY_ON_BUILD="0"
RUN_PLAYWRIGHT_INSTALL_ON_BUILD="0"

# App URLs
APP_BASE_URL="https://sneekholdings.com"
APP_URL="https://sneekholdings.com"
TZ="Australia/Sydney"

# Storage: Cloudflare R2 / S3-compatible
S3_BUCKET_NAME="your-production-bucket"
S3_REGION="auto"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
AWS_ACCESS_KEY_ID="replace-with-r2-access-key"
AWS_SECRET_ACCESS_KEY="replace-with-r2-secret-key"
S3_PUBLIC_BASE_URL="https://pub-<hash>.r2.dev"

# Email: Resend
RESEND_API_KEY="re_xxxxxx"
EMAIL_FROM="admin@sneekholdings.com"

# SMS: Twilio (optional)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
TWILIO_PHONE_NUMBER="+61000000000"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="replace-with-google-maps-api-key"

# Upload limits
VIDEO_MAX_UPLOAD_MB="300"
