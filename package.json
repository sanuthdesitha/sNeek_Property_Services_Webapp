{
  "name": "sneek-ops-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/ensure-prisma-client.cjs",
    "dev": "node ./scripts/run-next.cjs dev -H 0.0.0.0 -p 3000",
    "prebuild": "node ./scripts/prebuild.cjs",
    "build": "node ./scripts/run-next.cjs build",
    "prestart": "node ./scripts/ensure-prisma-client.cjs",
    "start": "node ./scripts/run-next.cjs start -H 0.0.0.0 -p 3000",
    "setup:runtime": "npm run db:deploy && npm run admin:bootstrap && npm run playwright:install",
    "lint": "next lint",
    "predeploy:check": "tsx scripts/predeploy-check.ts",
    "backup:create": "tsx scripts/backup/create-backup.ts --include-uploads --json-export",
    "backup:restore": "tsx scripts/backup/restore-backup.ts --confirm",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "node ./scripts/run-seed-demo.cjs",
    "db:generate": "prisma generate",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "playwright:install": "playwright install chromium",
    "workers:dev": "tsx watch workers/boss.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/resource-timeline": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-table": "^8.20.5",
    "aws-sdk": "^2.1691.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ffmpeg-static": "^5.2.0",
    "ical.js": "^2.0.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.453.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.7",
    "pg-boss": "^9.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.3.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
